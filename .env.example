# LINE Messaging API
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# Google OAuth2
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_google_refresh_token_here

# Google Sheets
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Google Drive
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here
GOOGLE_DRIVE_KB_FOLDER_ID=your_drive_knowledge_base_folder_id_here

# Google Maps Geocoding
GOOGLE_MAPS_API_KEY=your_maps_api_key_here

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (optional — enables dual-write alongside Google Sheets)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# Telegram (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_TOKEN_2=your_second_bot_token_here

# Optional overrides
# GOOGLE_CALLBACK_URL=https://bot.your-domain.com/oauth2callback
# BOT_QUEUE_MODE=memory

# Public URL the bot is reachable on (Cloudflare Tunnel, ngrok, reverse proxy).
# Used to register Telegram webhooks and as the fallback for GOOGLE_CALLBACK_URL.
# Leave blank when running purely locally.
# EXTERNAL_BASE_URL=https://bot.your-domain.com

# Dashboard write-API key (required in production for /api/reports/:id/* writes)
# DASHBOARD_API_KEY=generate-a-long-random-string

# Logging: debug | info | warn | error  (default: info)
# LOG_LEVEL=info

# Server
PORT=3000
NODE_ENV=development
